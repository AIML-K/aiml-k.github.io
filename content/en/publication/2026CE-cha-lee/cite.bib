@ARTICLE{Cha2026-xx,
  title    = "{Consequence-Guided Information Extraction for Predicting Central
              Bank Communication’s Effect}",
  author   = "Cha, Taehun and Lee, Donghun",
  journal  = "Computational Economics",
  abstract = "Predicting how financial markets respond to central bank
              communications is a key challenge in economics and finance.
              However, central bank communications are relatively rare events,
              making it challenging to apply standard data science methods. To
              address this issue, we focus on the characteristics of central
              bank communications, especially those from the FOMC, which
              typically consist of a short statement and a full-length minute.
              We introduce a consequence-guided information extraction system
              that utilizes state-of-the-art natural language processing and
              reinforcement learning techniques. Utilizing the pre-trained BERT
              prediction as a reward signal, we train a model to highlight the
              most influential text span in FOMC minutes. Then, we apply the
              Open Information Extraction system to obtain the structured
              information tuples from the highlighted span. By using it as a
              feature extractor, we achieve 77-86\% accuracy in predicting the
              future direction of the various economic variables, compared to
              43–66\% accuracy from standard natural language processing methods
              such as bag-of-words, topic modeling, and fine-tuned BERT. Our
              study shows how a model with limited capacity can be improved when
              combined with a proper structure, especially in a data-scarce
              situation.",
  month    =  mar,
  year     =  2026,
  date     =  {2026-03-13},
  doi      =  {10.1007/s10614-025-11284-6},
  issn     =  "1572-9974",
  url      =  {https://doi.org/10.1007/s10614-025-11284-6},
}